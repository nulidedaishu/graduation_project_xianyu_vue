{
  "name": "xianyu_vue",
  "private": true,
  "version": "1.0.0",
  "description": "闲鱼二手交易平台 - Vue 3 + TypeScript + Element Plus + Vite",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
